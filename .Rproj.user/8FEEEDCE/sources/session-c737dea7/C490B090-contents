#Create data objects with various levels of aggregation
dat_ward =  dhis2 %>%
  dplyr::select(-organisationunitname) %>%
  group_by(date, State, LGA, Ward) %>%
  summarise_all(sum, na.rm = T) %>%
  left_join(dhis2_hf) %>%
  mutate(rhcc2_m_d = rhcc2_m_n + rhcc2_m_d,
         rhcc2_p_d = rhcc2_p_n + rhcc2_p_d,
         rhcc2_d_d = rhcc2_d_n + rhcc2_d_d,
         Ward = str_remove(Ward, " ward") %>% str_remove(., "Ke ")) %>% #Add community data to RHCC2 denominators
  left_join(trained_chws) %>%
  left_join(pop) %>%
  left_join(equipped_chws) %>%
  mutate(adm0 = "NGA",
         rhcc1 = ifelse(State=="Kebbi", 159, 80), 
         `RHCC Target (iCCM services)` = 2292,
         `RHCC Target (other)` = 458) %>%
  ungroup() %>%
  mutate(rhcc2_m = round(rhcc2_m_n/rhcc2_m_d*100),
         rhcc2_p = round(rhcc2_p_n/rhcc2_p_d*100),
         rhcc2_d = round(rhcc2_d_n/rhcc2_d_d*100),
         rhcc2.1 = round(rhcc2.1_n/rhcc2.1_d*100),
         rhcc2.2 = round(rhcc2.2_n/rhcc2.2_d*100),
         rhcc2.3 = round(rhcc2.3_n/rhcc2.3_d*100),
         rhcc2.4 = round(rhcc2.4_n/rhcc2.4_d*100),
         rhcc2.5 = round(rhcc2.5_n/rhcc2.5_d*100),
         rhcc4 = rhcc4_f,
         rhcc5 = round(rhcc4/rhcc5_d*1000),
         rhcc9 = round(rhcc9_n/rhcc9_d*100))

