pacman::p_load(readxl,tidyverse)

#Import data
setwd("~/Library/CloudStorage/Box-Box/MNTD/Projects/RHCC (Rotary)/Dashboard/data/raw/Nigeria/")

key = read_excel("ward_pop_name_key.xlsx")

ai_pop = read_excel("Akwa Ibom Ward Population_2025 HF microplan.xlsx") %>%
  filter(LGA!="Total") %>%
  dplyr::select(LGA, Ward, "rhcc5_d" = `CU5 population`)

k_pop = read_excel("Kebbi Ward Population_2025 mlos.xlsx") %>%
  filter(lga!="Total") %>%
  dplyr::select("LGA" = lga, "Ward" = ward, "rhcc5_d" = `CU5 population`)

pop = ai_pop %>%
  bind_rows(k_pop) %>%
  left_join(key %>% dplyr::select(-State), by = c("LGA", "Ward" = "Ward_pop")) %>%
  mutate(Ward = ifelse(!is.na(Ward.y), Ward.y, Ward),
         Ward = stringr::str_replace_all(Ward, "\\s", " "),
         Ward = ifelse(Ward=="Ikot Ibritam 1", "Ikot Ibritam  1", Ward)) %>%
  dplyr::select(-Ward.y)

dhis2_hf = read.csv("iCCM cases at HFs in RHCC wards - Nov-2025 to Jan-2026_10.03.2026.csv") %>%
  mutate(across(orgunitlevel1:orgunitlevel4, ~str_remove(., "ak ")),
         across(orgunitlevel1:orgunitlevel4, ~str_remove(., "ke "))) %>%
  mutate(State = ifelse(orgunitlevel2=="Akwa-Ibom State", "Akwa Ibom", "Kebbi"),
         LGA = str_remove(orgunitlevel3, " Local Government Area"),
         Ward = str_remove(orgunitlevel4, "Ward") %>% str_trim("right")) %>%
  mutate(rhcc2_m_d = Persons.with.fever..5yrs,
         rhcc2_p_d = rowSums(across(c(Pneumonia.new.cases...5.years.Female,
                                      Pneumonia.new.cases...5.years.Male)), na.rm = T),
         rhcc2_d_d = rowSums(across(c(Diarrhoea.new.cases...5.years.Female,
                                      Diarrhoea.new.cases...5.years.Male)), na.rm = T),
         date = as.Date(paste(substr(periodid,1,4), substr(periodid,5,6), "01", sep = "-"))) %>%
  dplyr::select(date,State,LGA,Ward,rhcc2_m_d,rhcc2_p_d,rhcc2_d_d)
                        
dhis2 = read_excel("dhis2.xls") %>%
  mutate(across(orgunitlevel1:orgunitlevel4, ~str_remove(., "ak ")),
         across(orgunitlevel1:orgunitlevel4, ~str_remove(., "ke "))) %>%
  mutate(date = as.Date(paste(periodname, "01", sep = " "), 
                 format = "%B %Y %d"),
         State = ifelse(orgunitlevel2=="Akwa-Ibom State", "Akwa Ibom", "Kebbi"),
         LGA = str_remove(orgunitlevel3, " Local Government Area"),
         Ward = str_remove(orgunitlevel4, "Ward") %>% str_trim("right"),
         rhcc9_n = rowSums(across(c(`RHCC - Children Under 5 Referred for Danger Signs Female`,
                                    `RHCC - Children Under 5 Referred for Danger Signs Male`)), na.rm = T),
         rhcc9_d = rowSums(across(c(`RHCC - Children Under 5 Visited Female`,
                                    `RHCC - Children Under 5 Visited Male`)), na.rm = T),
         rhcc2_d_n = rowSums(across(c(`RHCC - Children Under 5 with Diarrhea Female`,
                                      `RHCC - Children Under 5 with Diarrhea Male`)), na.rm = T),
         rhcc2.4_d = rhcc2_d_n,
         rhcc2.4_n = rowSums(across(c(`RHCC - Children Under 5 with Diarrhea Treated with ORS + Zinc Female`,
                                      `RHCC - Children Under 5 with Diarrhea Treated with ORS + Zinc Male`)), na.rm = T),
         rhcc2_p_n = rowSums(across(c(`RHCC - Children Under 5 with Identified with Fast Breathing Female`,
                                      `RHCC - Children Under 5 with Identified with Fast Breathing Male`)), na.rm = T),
         rhcc2.5_d = rhcc2_p_n,
         rhcc2.5_n = rowSums(across(c(`RHCC - Children Under 5 with Fast Breathing Treated with Amoxicillin Female`,
                                      `RHCC - Children Under 5 with Fast Breathing Treated with Amoxicillin Male`)), na.rm = T),
         rhcc2_m_n = rowSums(across(c(`RHCC - Children Under 5 with Fever Female`,
                                      `RHCC - Children Under 5 with Fever Male`)), na.rm = T),
         rhcc2.1_d = rhcc2_m_n,
         rhcc2.1_n = rowSums(across(c(`RHCC - Children Under 5 with Fever Tested for Malaria with RDT Female`,
                                      `RHCC - Children Under 5 with Fever Tested for Malaria with RDT Male`)), na.rm = T),  
         rhcc2.3_n = rowSums(across(c(`RHCC - Confirmed Malaria Cases Treated with ACT Female`,
                                      `RHCC - Confirmed Malaria Cases Treated with ACT Male`)), na.rm = T),
         rhcc2.3_d = rowSums(across(c(`RHCC - Confirmed RDT Positive Cases Female`,
                                      `RHCC - Confirmed RDT Positive Cases Male`)), na.rm = T),
         rhcc2.2_n = rhcc2.3_d,
         rhcc2.2_d = rhcc2.1_n) %>%
  dplyr::select(date,State,LGA,Ward,organisationunitname,rhcc2_m_n,rhcc2_p_n,rhcc2_d_n,rhcc2.1_n,rhcc2.1_d,rhcc2.2_n,rhcc2.2_d,
                rhcc2.3_n,rhcc2.3_d,rhcc2.4_n,rhcc2.4_d,rhcc2.5_n,rhcc2.5_d,rhcc9_n,rhcc9_d,
                "rhcc13_n" = `4 - Service Summary (Monthly) - Actual reports on time`,
                "rhcc13_d" = `4 - Service Summary (Monthly) - Expected reports`)

supervision = read_excel("CHIPS_Agent_Supervision_Checklist_October_2025_-_all_versions_-_labels_-_2025-11-19-23-12-16.xlsx") %>%
  bind_rows(read_excel("CHIPS_Agent_Supervision_Checklist_2026_-_all_versions_-_labels_-_2026-03-09-21-35-31.xlsx")) %>%
  dplyr::select(`Date and time of visit`, `State`,"LGA" = `Local Government Area`,`Ward`,"organisationunitname" = `Health Facility`,
                `Supervisor`,`CHIPS Agent`,`Was the number of breaths per minute counted correctly`,
                `Did you have Dispersible Amoxicillin every day last month?`,
                `Did you have Low Osmolar ORS everyday last month?`, `Did you have Zinc tablet everyday last month?`,
                `Did you have antimalarial every day last month?`) %>%
  mutate(date = floor_date(ymd(substr(`Date and time of visit`,1,10)), unit = "month")) %>%
  group_by(`CHIPS Agent`, date) %>%
  filter(row_number()==1) %>%
  group_by(State, date) %>%
  summarise(rhcc7_n = n_distinct(`CHIPS Agent`),
            rhcc8_n = sum(`Was the number of breaths per minute counted correctly`=="Yes", na.rm = T),
            rhcc8_d = sum(!is.na(`Was the number of breaths per minute counted correctly`)),
            rhcc12_m_n = sum(`Did you have antimalarial every day last month?`=="Yes", na.rm = T), 
            rhcc12_m_d = sum(!is.na(`Did you have antimalarial every day last month?`)), 
            rhcc12_p_n = sum(`Did you have Dispersible Amoxicillin every day last month?`=="Yes", na.rm = T),
            rhcc12_p_d = sum(!is.na(`Did you have Dispersible Amoxicillin every day last month?`)),
            rhcc12_d_n = sum(`Did you have Low Osmolar ORS everyday last month?`=="Yes" & `Did you have Zinc tablet everyday last month?`=="Yes"),
            rhcc12_d_d = sum(!is.na(`Did you have Low Osmolar ORS everyday last month?`) & !is.na(`Did you have Zinc tablet everyday last month?`)),
            adm0 = "NGA")

