## Predictors of reduced productivity

Depression and lethargy were the only statistically significant predictor of reduced productivity.

```{r echo = F}
dat2 = dat %>%
  mutate(across(c(2:17), ~.-1))
  
formula = "productivity ~ cycle"
initial_model = lm(formula, data = dat2)
AIC = AIC(initial_model)
results = summary(initial_model)$coefficients

for(covariate in names(dat2)[c(5:18)]){
  model = lm(as.formula(paste0(formula, " + `", covariate, "`")),
             data = dat2)
  
  if(AIC(model)<AIC) formula = paste0(formula , " + `", covariate, "`") #If the covariate reduces the AIC, update the model
  if(AIC(model)<AIC) results = summary(model)$coefficients #Save the new model results

  if(AIC(model)<AIC) AIC = AIC(model) #Update the QIC
}

table = results %>% 
  as.data.frame() %>% 
  mutate(`95% CI` = paste(sprintf("%.2f", round(Estimate-1.96*`Std. Error`,2)),
                    sprintf("%.2f", round(Estimate+1.96*`Std. Error`,2)), sep = ", ")) %>%
  rename(`p-value` = `Pr(>|t|)`) %>%
  dplyr::select(1,5,4,-2,-3) %>%
  mutate(across(c(1,3), ~round(.,2)))

